{
  "name": "test-app-combined",
  "version": "0.0.0",
  "private": true,
  "description": "Test Ember app for vite-ember-ssr combined SSR + SSG mode",
  "license": "MIT",
  "exports": {
    "./*": "./app/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
