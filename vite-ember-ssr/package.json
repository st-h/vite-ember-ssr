{
  "name": "vite-ember-ssr",
  "version": "0.1.0-alpha.13",
  "description": "Vite plugin and SSR runtime for Ember.js applications using HappyDOM",
  "type": "module",
  "license": "MIT",
  "author": "Liam Potter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evoactivity/vite-ember-ssr.git",
    "directory": "packages/vite-ember-ssr"
  },
  "homepage": "https://github.com/evoactivity/vite-ember-ssr/tree/main/packages/vite-ember-ssr#readme",
  "bugs": "https://github.com/evoactivity/vite-ember-ssr/issues",
  "keywords": [
    "vite",
    "vite-plugin",
    "ember",
    "emberjs",
    "ssr",
    "server-side-rendering",
    "happydom",
    "embroider"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "happy-dom": "^20.8.9",
    "tinypool": "^2.1.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
