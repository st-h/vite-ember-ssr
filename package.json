  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "pnpm --filter vite-ember-ssr build && pnpm --filter test-app build:all",
    "clean": "rm -rf test-apps/*/dist && rm -rf vite-ember-ssr/dist",
    "demo": "pnpm build && pnpm --filter test-server start",
    "dev": "pnpm --filter test-server dev",
    "format": "prettier --write .",
    "test": "pnpm --filter vite-ember-ssr test",
    "test:all": "pnpm --filter vite-ember-ssr test:all",
    "test:browser": "pnpm --filter vite-ember-ssr test:browser"
